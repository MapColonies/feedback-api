{
  "openapiConfig": {
    "filePath": "./openapi3.yaml",
    "basePath": "/docs",
    "rawPath": "/api",
    "uiPath": "/api"
  },
  "telemetry": {
    "shared": {
      "serviceName": "feedback-api"
    },
    "tracing": {
      "isEnabled": false
    },
    "logger": {
      "level": "info",
      "prettyPrint": false
    }
  },
  "server": {
    "port": 8080,
    "request": {
      "payload": {
        "limit": "1mb"
      }
    },
    "response": {
      "compression": {
        "enabled": true,
        "options": null
      }
    }
  },
  "redis": {
    "host": "REDIS_HOST",
    "port": 6379,
    "username": "",
    "password": "",
    "tls": {
      "enabled": false
    },
    "connectTimeoutMs": 5000,
    "ttl": 600,
    "expiredResponseTtl": 300
  },
  "kafka": {
    "brokers": "KAFKA_URL:9092",
    "enableSslAuth": false,
    "sslPaths": {
      "ca": "",
      "key": "",
      "cert": ""
    },
    "consumer": {},
    "producer": {},
    "outputTopic": "topic"
  },
  "application": {
    "hashKey": {
      "enabled": false
    },
    "userValidation": ["@mycompany.net"]
  },
  "schema": {}
}
